#!/bin/sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/../../../../.." && pwd)
LOG_DIR="$REPO_ROOT/logs"
mkdir -p "$LOG_DIR"

child_pid=""

stop_server() {
    if [ -n "$child_pid" ]; then
        kill -TERM "$child_pid" 2>/dev/null || true
        wait "$child_pid" 2>/dev/null || true
    fi
}

trap stop_server HUP INT TERM

"$REPO_ROOT/.venv/bin/bactrack" serve \
    --host "${BACSTOP_HOST:-0.0.0.0}" \
    --port "${BACSTOP_PORT:-8000}" \
    >> "$LOG_DIR/server.log" \
    2>> "$LOG_DIR/server.error.log" &
child_pid=$!
wait "$child_pid"
